DATABASE_URL=postgresql://fs_sync:fs_sync@localhost:5432/fs_sync?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379
APP_ORIGIN=http://localhost:4200
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secrete
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google-drive/oauth/callback
GOOGLE_DRIVE_WEBHOOK_URL=https://<domain>/api/webhooks/google-drive
GOOGLE_DRIVE_ENABLE_WEBHOOKS=false
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-or-64-hex-key
GOOGLE_DRIVE_CHANGES_PAGE_SIZE=100
GOOGLE_DRIVE_INITIAL_FILES_PAGE_SIZE=100
GOOGLE_DRIVE_INITIAL_FILES_MAX_PAGES=5
